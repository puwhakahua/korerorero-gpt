# This is the base path for the application in urls
# eg localhost:3002/korerorero-gpt
# can be empty, in which case the application will be available at localhost:3002
# If you are proxying using apache, use a base path here
NEXT_PUBLIC_BASE_PATH=/korerorero-gpt

# This is the absolute path to the folder on the filesystem where we download the audio files to
FS_STORE_PATH=/greenstone/korerorero-gpt/audio-tmp

# Key for the Papa Reo language platform developed by Te Hiku Media - textToSpeech and speechToText
PAPAREO_API_KEY=

# Hugging face token for WMAI-Research/WM-TTS model - textToSpeech
HF_TOKEN_WMAI_RESEARCH=

# Token for accessing the API at api.puwhakahua.nz - textToSpeech
PUWHAKAHUA_API_KEY=

# Key for Anthropic, for Claude - chatLLM
ANTHROPIC_API_KEY=

# Hugging face token for KingsleyEng/Maori-TTS model - textToSpeech (shouldn't need this)
HF_TOKEN_KINGSLEYENG=

# Key if you want to use OpenAI for any of the parts - textToSpeech, speechTotext, chatLLM
# Note: OpenAI mustn't be used in a Pipeline together with PapaReo.
OPENAI_API_KEY=

# Set this if you want to use OpenRouter
OPENROUTER_API_KEY=

# Set these if you are behind a proxy
http_proxy=
https_proxy=



